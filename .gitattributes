# Set default behavior to automatically normalize line endings.
* text=auto

# Enforce LF line endings for text/code files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.editorconfig text eol=lf
.prettierrc text eol=lf
.gitignore text eol=lf
